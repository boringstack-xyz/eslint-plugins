{
  "name": "@boring-stack-pkg/eslint-plugin-test-conventions",
  "version": "0.1.0",
  "description": "ESLint rules that catch the most common test-suite mistakes: focused tests, direct DB access from tests, and orphaned test files.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AI-Starter-Templates/eslint-plugins.git",
    "directory": "eslint-plugin-test-conventions"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "README.md",
    "examples"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "typescript",
    "testing",
    "vitest",
    "jest",
    "test-conventions"
  ],
  "peerDependencies": {
    "@typescript-eslint/parser": ">=8.0.0",
    "eslint": "8.57.0 || ^9.0.0",
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "8.0.0",
    "micromatch": "4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "9.0.0",
    "@types/micromatch": "4.0.9",
    "@types/node": "22.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "@typescript-eslint/rule-tester": "8.0.0",
    "eslint": "9.0.0",
    "tsup": "8.0.0",
    "typescript": "6.0.3",
    "vitest": "2.0.0"
  }
}
